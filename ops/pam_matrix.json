      "path": "/stores?country=PE",
      "expect": {
        "status": 200,
        "json_path_min_count": {
          "stores": 1
        }
      }
    },
    {
      "id": "public.countries",
      "tier": 1,
      "phase": "public",
      "name": "Countries catalog",
      "method": "GET",
      "path": "/countries",
      "expect": {
        "status": 200,
        "json_has": [
          "countries"
        ],
        "json_path_min_count": {
          "countries": 5
        }
      }
    },
    {
      "id": "public.sources_health",
      "tier": 1,
      "phase": "public",
      "name": "Per-store source health",
      "method": "GET",
      "path": "/v1/sources/health",
