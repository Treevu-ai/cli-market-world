      "path": "/products/compare",
      "auth": "user",
      "timeout_s": 60,
      "body": {
        "query": "leche",
        "country": "PE",
        "limit": 3
      },
      "expect": {
        "status": 200,
        "json_has": [
          "comparison",
          "query"
        ]
      }
    },
