{
  "version": "1.0.0",
  "product": "CLI Market",
  "updated": "2026-06-06",
  "defaults": {
    "api_base": "https://cli-market-production.up.railway.app",
    "landing_base": "https://cli-market.dev",
    "timeout_s": 30
  },
  "thresholds": {
    "min_indexed": 1000,
    "min_collector_succeeded": 30,
    "max_collector_age_hours": 12,
    "max_search_latency_ms": 45000
  },
  "manual_checklist": [
    {
      "id": "cli.pip_install",
      "phase": "manual",
      "tier": 1,
      "name": "pip install cli-market en venv limpio",
      "steps": "python -m venv /tmp/pam-venv && pip install -U cli-market && market hello"
    },
    {
      "id": "cli.journey",
      "phase": "manual",
      "tier": 1,
      "name": "CLI journey básico",
      "steps": "market login → market search leche --country PE → market compare → market whoami"
    },
    {
      "id": "mcp.cursor",
      "phase": "manual",
      "tier": 1,
      "name": "MCP desde mcp.json de cli-market.dev",
      "steps": "Conectar MCP, market_search + market_compare + market_cart_list"
    },
    {
      "id": "landing.visual",
      "phase": "manual",
      "tier": 1,
      "name": "Landing pricing + contact + stats",
      "steps": "Abrir cli-market.dev — números alineados con /dashboard/data"
    },
    {
      "id": "billing.pro",
      "phase": "manual",
      "tier": 2,
      "name": "E2E Pro request + PayPal sandbox",
      "steps": "Ver ops/E2E_CLIENT_JOURNEY.md — request-pro → activate_pro → market checkout"
    },
    {
      "id": "payments.mp",
      "phase": "manual",
      "tier": 2,
      "name": "Mercado Pago checkout sandbox",
      "steps": "market checkout con MP en cuenta Pro de prueba"
    }
  ],
  "cases": [
    {
      "id": "public.root",
      "tier": 1,
      "phase": "public",
      "name": "API root banner",
      "method": "GET",
      "path": "/",
      "expect": {
        "status": 200,
        "json": {
          "status": "running"
        }
      }
    },
    {
      "id": "public.health",
      "tier": 1,
      "phase": "public",
      "name": "Liveness /health",
      "method": "GET",
      "path": "/health",
      "expect": {
        "status": 200,
        "json": {
          "status": "healthy"
        }
      }
    },
    {
      "id": "public.health_db",
      "tier": 1,
      "phase": "public",
      "name": "Database backend diagnostic",
      "method": "GET",
      "path": "/health/db",
      "expect": {
        "status": 200,
        "json_has": [
          "backend"
        ]
      }
    },
    {
      "id": "public.health_collector",
      "tier": 1,
      "phase": "public",
      "name": "Collector freshness + batch success",
      "method": "GET",
      "path": "/health/collector",
      "expect": {
        "status": 200,
        "json": {
          "status": "ok",
          "in_progress": false
        },
        "json_min": {
          "stores_succeeded": "{{threshold.min_collector_succeeded}}"
        },
        "json_max": {
          "age_hours": "{{threshold.max_collector_age_hours}}"
        }
      }
    },
    {
      "id": "public.lines",
      "tier": 1,
      "phase": "public",
      "name": "Business lines catalog",
      "method": "GET",
      "path": "/lines",
      "expect": {
        "status": 200,
        "json_has": [
          "lines",
          "total"
        ],
        "json_path_min_count": {
          "lines": 6
        }
      }
    },
    {
      "id": "public.stores",
      "tier": 1,
      "phase": "public",
      "name": "Retailers catalog (no 500)",
      "method": "GET",
      "path": "/stores",
      "expect": {
        "status": 200,
        "json_has": [
          "stores",
          "total"
        ],
        "json_path_min_count": {
          "stores": 30
        }
      }
    },
    {
      "id": "public.stores_pe",
      "tier": 1,
      "phase": "public",
      "name": "Stores filtered by country PE",
