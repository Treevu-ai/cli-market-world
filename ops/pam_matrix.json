      "path": "/v1/retailers/apply",
      "body": {
        "store_name": "PAM Test Store {{run_id}}",
        "website": "https://example.com",
        "country": "PE",
        "platform": "woocommerce",
        "contact_email": "pam+{{run_id}}@cli-market.dev",
        "catalog_size": "small"
      },
      "expect": {
        "status_in": [
          200,
          201
        ],
        "json_has": [
          "application_id"
        ]
      }
    },
    {
      "id": "public.utils_exchange",
      "tier": 2,
      "phase": "public",
      "name": "FX conversion utility",
      "method": "POST",
      "path": "/v1/utils/exchange",
      "body": {
        "amount": 100,
        "from": "USD",
        "to": "PEN"
      },
      "expect": {
        "status": 200,
        "json_has": [
          "converted",
          "rate"
        ]
      }
    },
    {
