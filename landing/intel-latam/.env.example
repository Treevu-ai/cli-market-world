# MARKET_API_URL: Base URL of the real CLI Market API (the Data Moat).
# Defaults to production if unset.
MARKET_API_URL="https://cli-market-api.fly.dev"

# MARKET_API_TOKEN: Bearer token for a Starter+ tier account, used to call
# POST /v1/intel/ask. Without this, the chat demo shows a clear "not
# connected" message instead of any invented data.
MARKET_API_TOKEN="MY_MARKET_API_TOKEN"

# ADMIN_API_TOKEN: Real admin bearer token for the CLI Market API, used only
# server-side to call POST /admin/activate-pro-request (manual Pro/Procure
# activation). NEVER exposed to the browser -- leave unset to disable the
# "Activar Pro" panel entirely (it responds 501 without it).
ADMIN_API_TOKEN=""

# ADMIN_UI_PASSPHRASE: A local, low-stakes passphrase you set yourself to
# gate the "Activar Pro" panel in the UI. This is NOT the admin token itself
# -- it's checked here, server-side, before the real (much more privileged)
# ADMIN_API_TOKEN is ever used. Anyone who doesn't know this can't trigger
# a real activation, even if they find the panel.
ADMIN_UI_PASSPHRASE=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
