    {"name": "market_basket", "description": "Optimize a multi-item basket across retailers", "inputSchema": {"type": "object", "properties": {"items": {"type": "array"}, "country": {"type": "string"}}, "required": ["items", "country"]}},
    {"name": "market_cart", "description": "View current cart contents", "inputSchema": {"type": "object", "properties": {}}},
    {"name": "market_cart_update", "description": "Add or update items in cart", "inputSchema": {"type": "object", "properties": {"product_id": {"type": "string"}, "quantity": {"type": "integer"}}, "required": ["product_id"]}},
    {"name": "market_cart_remove", "description": "Remove items from cart", "inputSchema": {"type": "object", "properties": {"product_id": {"type": "string"}}, "required": ["product_id"]}},
