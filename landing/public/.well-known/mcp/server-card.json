    {"name": "market_indicators", "description": "34 market indicators from public sources", "inputSchema": {"type": "object", "properties": {"country": {"type": "string"}}}},
    {"name": "market_scores", "description": "Retailer quality scores", "inputSchema": {"type": "object", "properties": {}}},
    {"name": "market_intel_refresh", "description": "Refresh market intelligence data", "inputSchema": {"type": "object", "properties": {}}},
    {"name": "market_enrichment", "description": "Product enrichment data", "inputSchema": {"type": "object", "properties": {"query": {"type": "string"}}}},
    {"name": "market_enrichment_subcategories", "description": "Subcategory enrichment data", "inputSchema": {"type": "object", "properties": {}}},
