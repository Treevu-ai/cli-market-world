    {"name": "market_stock", "description": "Check product stock availability", "inputSchema": {"type": "object", "properties": {"product_id": {"type": "string"}, "country": {"type": "string"}}, "required": ["product_id"]}},
    {"name": "market_brands", "description": "List available brands", "inputSchema": {"type": "object", "properties": {"country": {"type": "string"}}}},
    {"name": "market_favorites", "description": "Manage favorite products", "inputSchema": {"type": "object", "properties": {}}},
    {"name": "market_notify", "description": "Configure notifications", "inputSchema": {"type": "object", "properties": {}}},
    {"name": "market_exchange", "description": "Currency exchange rates", "inputSchema": {"type": "object", "properties": {"from": {"type": "string"}, "to": {"type": "string"}}, "required": ["from", "to"]}},
    {"name": "market_delivery", "description": "Delivery estimates by retailer", "inputSchema": {"type": "object", "properties": {"retailer": {"type": "string"}, "country": {"type": "string"}}, "required": ["country"]}},
    {"name": "market_login", "description": "Authenticate with CLI Market", "inputSchema": {"type": "object", "properties": {"username": {"type": "string"}, "password": {"type": "string"}}, "required": ["username", "password"]}},
    {"name": "market_lines", "description": "List business lines", "inputSchema": {"type": "object", "properties": {}}}
  ]
