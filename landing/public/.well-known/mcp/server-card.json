    {"name": "market_alerts", "description": "Create or manage price alerts", "inputSchema": {"type": "object", "properties": {"product_id": {"type": "string"}, "threshold": {"type": "number"}}}},
    {"name": "market_whoami", "description": "Current user and plan info", "inputSchema": {"type": "object", "properties": {}}},
