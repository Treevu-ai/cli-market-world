# Copiar a .env (local, gitignored) — nunca commitear valores reales
# Workspace: climarketworspace — ver docs/ops/slack-setup.md
SLACK_BOT_TOKEN=xoxb-reemplazar
# #bitácora-diaria-cli · #publicaciones-redes · #revisiones-cursor
SLACK_CHANNEL_BITACORA=C0B6V3Y9ZSP
SLACK_CHANNEL_PUBLICACIONES=C0B6ZJ1B9B8
SLACK_CHANNEL_REVISIONES_CURSOR=C0B723TQS78

# Opcional: webhooks por canal (alternativa al bot token)
# SLACK_WEBHOOK_BITACORA=
# SLACK_WEBHOOK_PUBLICACIONES=
# SLACK_WEBHOOK_REVISIONES_CURSOR=

# Briefing / dashboard
# DASHBOARD_DATA_URL=https://cli-market-production.up.railway.app/dashboard/data
# Día 1 de la campaña 30d (reset 2026-05-29 — ver content repo linkedin/catch-up-plan.md)
# LINKEDIN_CAMPAIGN_START=2026-05-29

# Repo privado de posts + assets (fuera de cli-market-world)
# CLI_MARKET_CONTENT_DIR=../cli-market-content

# Credenciales por tienda (Railway / .env local — nunca commitear valores reales)
# Activa tiendas con enable_with_credentials en market_stores.py
# STORE_FALABELLA_PE_MAGENTO_TOKEN=integration-token-read-only
# STORE_GYMSHARK_STOREFRONT_TOKEN=shpat_...
# STORE_WONG_VTEX_APP_KEY=vtexappkey-...
# STORE_WONG_VTEX_APP_TOKEN=...

# Aprobación self-serve (alternativa a env manual):
# python3 ops/approve_retailer.py list
# python3 ops/approve_retailer.py approve RET-XXXXXXXX --store-id falabella_pe
# curl -H "Authorization: Bearer $MARKET_API_TOKEN" \
#   -X POST https://api.../admin/retailer-applications/RET-XXX/approve \
#   -d '{"store_id":"falabella_pe"}'

# Collector — refresh automático de indicadores del data moat tras cada corrida (default: 1)
# INDICATOR_AUTO_REFRESH=1
# Enriquecimiento OFF/Wiki/clima en el mismo ciclo (default: 1)
# ENRICHMENT_AUTO_REFRESH=1
# Muestras OFF por país por corrida (default: 12)
# ENRICH_SAMPLE_SIZE=12
# SUBCATEGORY_AUTO_REFRESH=1
# TIER2_AUTO_REFRESH=1
