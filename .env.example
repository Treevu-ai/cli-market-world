# ── API server (Railway) ──────────────────────────────────────────────────────
MARKET_DATA_DIR=./data
CORS_ORIGINS=https://cli-market.dev,http://localhost:3000

# ── Manual Pro billing (default) ─────────────────────────────────────────────
PRO_PAYMENT_URL=https://www.paypal.com/ncp/payment/B6YVFTG4MA73J
PRO_PRICE_LABEL=$49/month
BILLING_FROM_EMAIL=hello@cli-market.dev
BILLING_NOTIFY_EMAIL=hello@cli-market.dev
BILLING_FROM_NAME=CLI Market

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=hello@cli-market.dev
SMTP_PASSWORD=
SMTP_USE_TLS=true

# ── Rate limits ───────────────────────────────────────────────────────────────
RATE_LIMIT_MIN=60
RATE_LIMIT_DAY=1000
RATE_LIMIT_WINDOW=60

# ── Checkout (Pro tier) ───────────────────────────────────────────────────────
MARKET_LEGACY_CHECKOUT=0
YAPE_PLIN_NUMBER=

