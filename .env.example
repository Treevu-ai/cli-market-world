# CLI Market Environment Configuration
# Copy this file to .env and fill in your values

# API Configuration
MARKET_API_URL=https://cli-market-production.up.railway.app
MARKET_API_KEY=your_api_key_here

# Authentication
MARKET_USERNAME=your_username
MARKET_PASSWORD=your_secure_password

# Database
DATABASE_URL=postgresql://user:password@host:port/dbname

# PayPal Integration
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# SMTP Configuration (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=hello@cli-market.dev
SMTP_PASSWORD=your_gmail_app_password
SMTP_USE_TLS=true
# Gmail drafts on Pro activation (IMAP; same app password as SMTP)
GMAIL_DRAFTS_ENABLED=true

# Dashboard Admin
ADMIN_API_KEY=your_admin_api_key

# Security
SECRET_KEY=your_random_secret_key_for_jwt_tokens

# Development
DEBUG=false

# GTM / content calendar (local ops — override Railway if stale)
LINKEDIN_CAMPAIGN_START=2026-06-01
LINKEDIN_PERSONAL_DAY_OFFSET=0
LINKEDIN_COMPANY_DAY_OFFSET=-1
